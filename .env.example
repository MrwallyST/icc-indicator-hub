# Required — your secret API key for adding indicators
API_KEY=your-secret-key-here

# Required — GitHub Personal Access Token with repo write scope
# Create at: https://github.com/settings/tokens/new
# Select scope: repo (full) or contents:write on your repo
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username (default: MrwallyST)
GITHUB_OWNER=MrwallyST

# The repo name (default: icc-indicator-hub)
GITHUB_REPO=icc-indicator-hub